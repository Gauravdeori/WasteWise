# Copy this file to ".env" and fill in your ThingSpeak keys.
# .env is gitignored, so the keys never reach the browser or the repository.
TS_CHANNEL_ID=your_channel_id
TS_READ_KEY=your_read_api_key
TS_WRITE_KEY=your_write_api_key

# OPTIONAL: 4-Channel Configuration (splits the 14 hostels across 4 channels)
# Channel 1: Hostels 1-4 (Brahmaputra, Subansiri, Lohit, Dhansiri Girls)
# TS_CHANNEL_1_ID=your_channel_1_id
# TS_READ_KEY_1=your_read_api_key_1
# TS_WRITE_KEY_1=your_write_api_key_1
# Channel 2: Hostels 5-8 (Manas, Kopili, Barak, Jia Bharali)
# TS_CHANNEL_2_ID=your_channel_2_id
# TS_READ_KEY_2=your_read_api_key_2
# TS_WRITE_KEY_2=your_write_api_key_2
# Channel 3: Hostels 9-11 (Pagladiya, Dikhow, Dhansiri Boys)
# TS_CHANNEL_3_ID=your_channel_3_id
# TS_READ_KEY_3=your_read_api_key_3
# TS_WRITE_KEY_3=your_write_api_key_3
# Channel 4: Hostels 12-14 (Kojoli Annex, Bhrigu, Neelachal)
# TS_CHANNEL_4_ID=your_channel_4_id
# TS_READ_KEY_4=your_read_api_key_4
# TS_WRITE_KEY_4=your_write_api_key_4

PORT=3000

# Admin auth — required for the "Log Reading" write endpoint.
# Set a strong random ADMIN_TOKEN, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_USER=admin
ADMIN_PASS=change_me
ADMIN_TOKEN=generate_a_long_random_string

# Account User API Key — required for the "Reset Data" button (clears the channel).
# Find it in ThingSpeak: Account -> My Profile -> User API Key.
TS_USER_API_KEY=your_thingspeak_user_api_key

# Cloudinary — hosts advertisement photos/videos for the hostel TVs.
# Create a free account at cloudinary.com -> Dashboard shows these 3 values.
# Without them the Ads dashboard still works, but only with pasted media URLs.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
