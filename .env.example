# Copy this file to ".env" and fill in your ThingSpeak keys.
# .env is gitignored, so the keys never reach the browser or the repository.
TS_CHANNEL_ID=your_channel_id
TS_READ_KEY=your_read_api_key
TS_WRITE_KEY=your_write_api_key
PORT=3000

# Admin auth — required for the "Log Reading" write endpoint.
# Set a strong random ADMIN_TOKEN, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_USER=admin
ADMIN_PASS=change_me
ADMIN_TOKEN=generate_a_long_random_string
